### ==========================================
### ADD A NEW AMBULANCE
### ==========================================

### Add Advanced Life Support Ambulance
POST {{host}}/api/ambulances
Content-Type: application/json
Idempotency-Key: {{$uuid}}
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJyb2xlIjoiQURNSU4iLCJzdWIiOiIyIiwiaWF0IjoxNzgxNTEyMzc2LCJleHAiOjE3ODE1OTg3NzZ9.J3EVcQ_rn6RZB_7x4mu2Zgn3RVU3JI1B--pRm2tJnZYZRQX61CKypRY0K2dhhZFV

{
  "registrationNumber": "DL-1D-AA-1123",
  "capabilities": "ALS, Ventilator, Defibrillator",
  "crewInfo": "2 Paramedics, 1 Driver"
}


