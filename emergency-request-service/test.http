### ==========================================
### ADD A NEW AMBULANCE
### ==========================================

### Add Advanced Life Support Ambulance
POST http://localhost:8080/api/ambulances
Content-Type: application/json
Idempotency-Key: {{$uuid}}
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJyb2xlIjoiQURNSU4iLCJzdWIiOiIyIiwiaWF0IjoxNzgxNDk5OTM0LCJleHAiOjE3ODE1ODYzMzR9._8ltUwEV3Ekl5MeEUnhz7Sxkv8PnDJYRn1cThAkeqJbCqvU0agXTshtcO4XO-vc6

{
  "registrationNumber": "DL-1C-AA-1123",
  "capabilities": "ALS, Ventilator, Defibrillator",
  "crewInfo": "2 Paramedics, 1 Driver"
}

